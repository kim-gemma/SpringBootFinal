<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="boot.data.mapper.IpgoMapperInter">
	<select id="getTotalCount" resultType="int">
		select count(*) from ipgo
	</select>
	<insert id="insertIpgo" parameterType="IpgoDto">
		insert into ipgo(sanpum,price,photoname,ipgoday) 
		values (#{sanpum},#{price},#{photoname},now())
	</insert>
	<select id="getAllSanpums" resultType="IpgoDto">
		select * from ipgo order by num
	</select>
</mapper>